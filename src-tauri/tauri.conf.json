{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timetabling Assistant",
  "version": "0.1.0",
  "identifier": "com.timetabling.desktop",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Timetabling Assistant",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "externalBin": [
      "../backend/dist/backend-sidecar"
    ]
  }
}
